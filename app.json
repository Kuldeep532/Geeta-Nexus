{
  "expo": {
    "name": "Bhagavad Gita AI",
    "slug": "gita-ai",
    "version": "2.1.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gita-ai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0d0a04"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kuldeep.gitaai"
    },
    "android": {
      "package": "com.kuldeep.gitaai",
      "versionCode": 2,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1a2744"
      },
      "permissions": [
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "56907911-a8ef-4d98-81d4-849ba14b8481"
      }
    },
    "owner": "kuldeep4"
  }
}
